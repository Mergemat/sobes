{
  "name": "sobes",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "concurrently --kill-others -n api,web \"tsx watch server/index.ts\" \"vite\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "fsd": "steiger src",
    "test": "vitest run",
    "check": "prettier . --check && eslint . && steiger src && vitest run && tsc -b && vite build",
    "start": "tsx server/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.9",
    "@tanstack/react-query": "^5.101.2",
    "hono": "^4.12.30",
    "nuqs": "^2.9.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "3.9.5",
    "steiger": "^0.6.0",
    "tsx": "^4.23.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
